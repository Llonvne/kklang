<idea-plugin>
    <id>cn.llonvne.kklang.idea</id>
    <name>kklang</name>
    <vendor>llonvne</vendor>
    <description>kklang .kk language support.</description>
    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
            name="kklang"
            language="kklang"
            implementationClass="cn.llonvne.kklang.idea.KkFileType"
            fieldName="INSTANCE"
            extensions="kk" />
        <lang.parserDefinition
            language="kklang"
            implementationClass="cn.llonvne.kklang.idea.KkParserDefinition" />
        <lang.syntaxHighlighterFactory
            language="kklang"
            implementationClass="cn.llonvne.kklang.idea.KkSyntaxHighlighterFactory" />
        <externalAnnotator
            language="kklang"
            implementationClass="cn.llonvne.kklang.idea.KkDiagnosticExternalAnnotator" />
        <configurationType
            implementation="cn.llonvne.kklang.idea.KkRunConfigurationType" />
        <runConfigurationProducer
            implementation="cn.llonvne.kklang.idea.KkRunConfigurationProducer" />
    </extensions>
</idea-plugin>
